# Database Neon PostgreSQL
# Ottieni da: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Password per accedere al pannello admin
ADMIN_PASSWORD="cambia-questa-password"

# Stringa casuale di 32 caratteri per firmare il cookie di sessione
# Genera con: openssl rand -hex 16
COOKIE_SECRET="00000000000000000000000000000000"

# Google OAuth — crea un'app su https://console.cloud.google.com
# Redirect URI: https://tuodominio.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Auth.js v5 secret — genera con: openssl rand -base64 32
AUTH_SECRET=""

# URL pubblico del sito (senza slash finale)
NEXTAUTH_URL="http://localhost:3000"
