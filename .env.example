# Database (Neon PostgreSQL)
# Ottieni da: https://neon.tech — usa branch separati per dev e produzione
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google OAuth
# Crea un'app su https://console.cloud.google.com
# Redirect URI: https://tuodominio.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Auth.js v5 secret — genera con: openssl rand -base64 32
AUTH_SECRET=""

# URL pubblico del sito (senza slash finale)
NEXTAUTH_URL="http://localhost:3000"

# Web Push (VAPID)
# Genera le chiavi una volta sola con:
#   node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# ATTENZIONE: cambiare le chiavi invalida tutte le subscription degli utenti
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="admin@karibubaskin.it"

# Email transazionali (Resend)
# Crea un account su https://resend.com
RESEND_API_KEY=""
CONTACT_EMAIL="asdkaribubaskin@gmail.com"

# Cron job secret (per /api/cron/cleanup-notifications)
# Genera con: openssl rand -base64 32
CRON_SECRET=""

# Test login — NON abilitare in produzione
ENABLE_TEST_LOGIN=false
TEST_PASSWORD="karibu-test"
