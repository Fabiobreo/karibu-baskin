# Database Neon PostgreSQL
# Ottieni da: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Password per accedere al pannello admin
ADMIN_PASSWORD="cambia-questa-password"

# Stringa casuale di 32 caratteri per firmare il cookie di sessione
# Genera con: openssl rand -hex 16
COOKIE_SECRET="00000000000000000000000000000000"
