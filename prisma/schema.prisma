generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enum ruoli applicativi ────────────────────────────────────────────────────

enum AppRole {
  GUEST
  ATHLETE
  PARENT
  COACH
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum MatchType {
  LEAGUE      // campionato
  TOURNAMENT  // torneo
  FRIENDLY    // amichevole
}

enum MatchResult {
  WIN
  LOSS
  DRAW
}

// ── Auth.js v5 — modelli standard (Prisma adapter) ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  appRole   AppRole @default(GUEST)
  slug      String? @unique  // es. "mario-rossi" — URL slug leggibile, generato dal nome

  // Campi atleta
  sportRole        Int?
  sportRoleVariant String?   // "S", "T", "P", "R" — null per variante standard
  gender           Gender?
  birthDate        DateTime?

  // Ruolo suggerito dall'autovalutazione (in attesa di conferma admin)
  sportRoleSuggested        Int?
  sportRoleSuggestedVariant String?

  accounts          Account[]
  authSessions      Session[]
  registrations     Registration[]
  children          Child[]             @relation("ParentChildren")
  childAccount      Child?              @relation("ChildUser")
  sportRoleHistory  SportRoleHistory[]
  pushSubscriptions PushSubscription[]
  teamMemberships   TeamMembership[]
  matchStats        PlayerMatchStats[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Push notifications ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  // null = utente non loggato (anonimo)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Storico ruolo sportivo atleta ────────────────────────────────────────────

model SportRoleHistory {
  id        String   @id @default(cuid())
  userId    String
  sportRole Int
  changedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
}

// ── Figli gestiti da un genitore (senza account proprio) ─────────────────────

model Child {
  id               String    @id @default(cuid())
  parentId         String
  name             String
  sportRole        Int?
  sportRoleVariant String?
  gender           Gender?
  birthDate        DateTime?
  createdAt        DateTime  @default(now())

  // Collegamento opzionale a un account User (se il figlio si registra in futuro)
  userId String? @unique

  parent          User             @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  user            User?            @relation("ChildUser", fields: [userId], references: [id], onDelete: SetNull)
  registrations   Registration[]
  teamMemberships TeamMembership[]
  matchStats      PlayerMatchStats[]

  @@index([parentId])
}

// ── Modelli esistenti (invariati nella tabella DB) ───────────────────────────

// Rinominato in Prisma per evitare conflitti con AuthSession,
// ma la tabella resta "Session" grazie a @@map
model TrainingSession {
  id            String         @id @default(cuid())
  title         String
  date          DateTime        // orario di inizio
  endTime       DateTime?       // orario di fine (nullable per retrocompatibilità)
  createdAt     DateTime       @default(now())
  teams         Json?
  dateSlug      String?        @unique  // es. "2025-03-15T18:00" — URL slug leggibile
  registrations Registration[]

  @@index([date])
  @@map("TrainingSession")
}

model Registration {
  id        String   @id @default(cuid())
  sessionId String
  name      String
  role      Int
  createdAt DateTime @default(now())

  // Chi è iscritto (al più uno non-null):
  // userId  → utente con account che si iscrive da solo
  // childId → figlio senza account, iscritto dal genitore
  // entrambi null → iscrizione anonima (legacy)
  userId  String?
  childId String?

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  child   Child?          @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@unique([sessionId, userId])
  @@unique([sessionId, childId])
  @@index([sessionId, role])
  @@index([userId])
  @@index([childId])
}

// ── Squadre agonistiche ───────────────────────────────────────────────────────

model Season {
  label     String   @id          // es. "2025-26"
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CompetitiveTeam {
  id           String   @id @default(cuid())
  name         String
  season       String   // es. "2024-25", "2025-26"
  championship String?  // es. "Gold Ovest", "Silver Ovest"
  color        String?  // colore hex (es. "#E65100")
  description  String?  @db.Text
  createdAt    DateTime @default(now())

  memberships TeamMembership[]
  matches     OfficialMatch[]

  @@index([season])
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  isCaptain Boolean  @default(false)
  createdAt DateTime @default(now())

  // Esattamente uno dei due deve essere valorizzato
  userId  String?
  childId String?

  team  CompetitiveTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user  User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child?          @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([teamId, childId])
  @@index([teamId])
  @@index([userId])
  @@index([childId])
}

// ── Squadre avversarie ────────────────────────────────────────────────────────

model OpposingTeam {
  id        String   @id @default(cuid())
  name      String
  city      String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  matches OfficialMatch[]
}

// ── Partite ufficiali ─────────────────────────────────────────────────────────

model OfficialMatch {
  id         String       @id @default(cuid())
  teamId     String
  opponentId String
  date       DateTime
  isHome     Boolean      @default(true)
  venue      String?
  matchType  MatchType    @default(LEAGUE)
  ourScore   Int?
  theirScore Int?
  result     MatchResult?
  notes      String?      @db.Text
  createdAt  DateTime     @default(now())

  team        CompetitiveTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  opponent    OpposingTeam       @relation(fields: [opponentId], references: [id])
  playerStats PlayerMatchStats[]

  @@index([teamId, date])
  @@index([opponentId])
}

// ── Statistiche giocatore per partita ────────────────────────────────────────

model PlayerMatchStats {
  id            String @id @default(cuid())
  matchId       String
  points        Int    @default(0)  // punti segnati
  baskets       Int    @default(0)  // canestri
  fouls         Int    @default(0)  // falli
  minutesPlayed Int?
  notes         String? @db.Text

  // Esattamente uno dei due deve essere valorizzato
  userId  String?
  childId String?

  match OfficialMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child?        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@unique([matchId, childId])
  @@index([matchId])
  @@index([userId])
  @@index([childId])
}
