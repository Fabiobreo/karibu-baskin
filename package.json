{
  "name": "karibu-baskin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rimraf -rf .next && next dev",
    "build": "prisma db push --skip-generate --accept-data-loss && prisma generate && next build",
    "db:deploy": "prisma migrate deploy",
    "start": "next start",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "email:dev": "react-email dev --dir src/emails --port 3333",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.8",
    "@mui/material-nextjs": "^7.3.9",
    "@mui/x-date-pickers": "^7.28.1",
    "@prisma/client": "^6.5.0",
    "@react-email/components": "^1.0.12",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^4.1.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.2",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-email/ui": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "prisma": "^6.5.0",
    "react-email": "^6.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
